# Available Computing Backend Configuration
# Copy this file to .env and fill in the values.

# Required: JWT secret for token signing
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Required: Admin login password
ADMIN_PASSWORD=

# Optional: Data directory (default: ./data)
# DATA_DIR=./data

# Optional: Custom whitelist YAML path (default: ../whitelist/providers.yaml)
# WHITELIST_PATH=./whitelist/providers.yaml

# Optional: Slow response threshold in ms (default: 1000)
# SLOW_THRESHOLD_MS=1000

# Docker secrets support (alternative to plain env vars):
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# ADMIN_PASSWORD_FILE=/run/secrets/admin_password
